# ===========================================================================
# ViceCityHub environment
#
# Copy this file to `.env.local` and fill in your Supabase project values.
# WITHOUT these, the site runs on bundled mock data (no DB, demo-only admin).
# WITH them, pages read from Supabase and admin sign-in uses Supabase Auth.
#
# Find these in your Supabase project: Settings → API
# ===========================================================================

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public site URL — used for SEO (canonical, sitemap, robots, social images).
# Set this in Vercel to your live URL, and update it when you add a custom domain.
NEXT_PUBLIC_SITE_URL=https://vicecityhub.vercel.app
